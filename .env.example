# Shared
NODE_ENV=development
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
COOKIE_DOMAIN=localhost

# API
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rally
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-random-bytes
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Email
RESEND_API_KEY=re_...
RESEND_FROM=Rally <hello@example.com>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Microsoft OAuth - reserved for Phase 2 calendar auth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
