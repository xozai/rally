# Rally environment variables
# Copy this file to .env for local development and configure matching
# production values in Vercel, Railway, Supabase, Upstash, and OAuth apps.

# ---------------------------------------------------------------------------
# Shared runtime
# ---------------------------------------------------------------------------

# Node runtime mode: development, test, or production.
NODE_ENV=development

# Public web app origin. Local Next.js defaults to http://localhost:3000.
WEB_URL=http://localhost:3000

# Public API origin. Local Fastify defaults to http://localhost:4000.
API_URL=http://localhost:4000

# Cookie domain for auth cookies. Use localhost locally, .rally.app in production.
COOKIE_DOMAIN=localhost

# ---------------------------------------------------------------------------
# API service - apps/api
# ---------------------------------------------------------------------------

# Fastify port used by the API service.
PORT=4000

# Supabase Postgres connection string used by Prisma.
# Use the pooled Supabase URL in production when possible.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rally

# Upstash Redis connection string used for queues and background work.
REDIS_URL=redis://localhost:6379

# Secret used to sign Rally session tokens. Must be at least 32 characters.
JWT_SECRET=replace-with-at-least-32-random-bytes

# Base64 or high-entropy secret used to encrypt provider tokens. Must be at least 32 characters.
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Resend API key for transactional email.
RESEND_API_KEY=re_...

# Verified sender identity used for Rally emails.
RESEND_FROM=Rally <hello@example.com>

# Google OAuth client for calendar connection and sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Microsoft OAuth client for calendar connection and sign-in.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback

# ---------------------------------------------------------------------------
# Web app - apps/web
# ---------------------------------------------------------------------------

# Browser-visible API URL consumed by Next.js pages and client components.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# CI/CD secrets - GitHub Actions
# ---------------------------------------------------------------------------

# Vercel deployment token.
VERCEL_TOKEN=

# Vercel team or user id that owns the web project.
VERCEL_ORG_ID=

# Vercel project id for apps/web.
VERCEL_PROJECT_ID=

# Railway API token used by GitHub Actions to deploy the api service.
RAILWAY_TOKEN=
